# Copy this file to .env and fill in real values. NEVER commit .env.
# This single .env is read by Hardhat (deploy), the helper scripts, and the
# backend (which loads ../../.env). For Render you set these as env vars instead.

# ── Blockchain RPC ────────────────────────────────────────────────
# LOCAL:  http://127.0.0.1:8545   (when running `npx hardhat node`)
# CLOUD:  your Sepolia RPC URL    (used by the backend at runtime)
RPC_URL=http://127.0.0.1:8545

# Sepolia RPC for `hardhat ... --network sepolia` deploy + helper scripts
# (Alchemy/Infura free tier, or a public Sepolia RPC)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer wallet private key (0x-prefixed).
# LOCAL: a Hardhat account key.  CLOUD: your FUNDED Sepolia wallet key.
DEPLOYER_PRIVATE_KEY=

# Deployed contract address (auto-written by scripts/deploy.js → contractInfo.json).
# On Render you can also set this explicitly.
CONTRACT_ADDRESS=

# Role wallet addresses (used by backend/scripts/initAdmin.js + scripts/fund.js).
# Simplest live setup: set all three to the deployer's address.
ADMIN_WALLET=
UNIVERSITY_WALLET=
EMPLOYER_WALLET=

# JWT
JWT_SECRET=replace_with_32+_char_random_string
JWT_EXPIRES_IN=8h

# AES-256 encryption key for sensitive MongoDB fields (exactly 64 hex chars)
ENCRYPTION_KEY=replace_with_64_hex_chars_0000000000000000000000000000000000000000000

# MongoDB
# LOCAL:  mongodb://127.0.0.1:27017/degree_attestation
# CLOUD:  your MongoDB Atlas connection string
MONGO_URI=mongodb://127.0.0.1:27017/degree_attestation

# Express port (Render injects its own PORT automatically)
PORT=4000

# ── AI verification agent (OPTIONAL) ──────────────────────────────
# The "Run AI analysis" button on the Requests review page. The agent picks an
# engine automatically: ANTHROPIC (if set) → GEMINI (if set) → rule-based offline.
# With NO key it still works (offline analyzer) — no cost, no setup.

# FREE option (recommended): Google Gemini. Create a free key — no credit card —
# at https://aistudio.google.com/apikey  (sign in with a Google account).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# PAID option: Anthropic Claude (needs a funded balance — separate from Claude Pro).
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
