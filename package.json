{
  "name": "degree-attestation",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "chain":    "hardhat node",
    "deploy":   "hardhat run scripts/deploy.js --network localhost",
    "backend":  "cd backend && npm start",
    "frontend": "cd frontend && npm run dev",
    "dev":      "concurrently --names CHAIN,BACKEND,FRONTEND --prefix-colors cyan,yellow,magenta \"npm run chain\" \"npm run backend\" \"npm run frontend\"",
    "compile":  "hardhat compile",
    "test":     "hardhat test",
    "seed":     "node scripts/seed.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "hardhat": "2.28.6"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "concurrently": "10.0.3",
    "dotenv": "16.6.1"
  }
}
